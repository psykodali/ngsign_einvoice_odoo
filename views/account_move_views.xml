<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_sign_ngsign_js" model="ir.actions.client">
        <field name="name">Sign with NGSign</field>
        <field name="tag">ngsign_einvoice_odoo.action_sign_ngsign_js</field>
    </record>

    <record id="view_move_form_inherit_ngsign" model="ir.ui.view">
        <field name="name">account.move.form.inherit.ngsign</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="ngsign_show_debug_button" invisible="1"/>
                <button name="ngsign_einvoice_odoo.action_sign_ngsign_js" string="Sign with NGSign" type="action" class="oe_highlight"
                        invisible="state != 'posted' or ngsign_status in ('pending', 'signed', 'TTN Signed', 'signed_ngsign')"/>
                <button name="action_check_ngsign_status" string="Check NGSign Status" type="object"
                        invisible="ngsign_status in ('draft', 'CANCELLED', 'TTN Signed')"/>
                <button name="action_generate_debug_json" string="Generate Debug JSON" type="object"
                        invisible="not ngsign_show_debug_button"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="eInvoice Info" name="einvoice_info">
                    <group>
                        <group>
                            <field name="ngsign_transaction_uuid" readonly="1" invisible="not ngsign_show_debug_button"/>
                            <field name="ngsign_invoice_uuid" readonly="1" invisible="not ngsign_show_debug_button"/>
                            <field name="ngsign_ttn_reference" readonly="1"/>
                            <field name="ngsign_ttn_qr_code" widget="image" readonly="1" invisible="not ngsign_ttn_qr_code"/>
                        </group>
                        <group>
                            <field name="ngsign_status" readonly="1"/>
                            <field name="ngsign_notify_owner" readonly="ngsign_status != 'draft'"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>


    <record id="view_invoice_tree_inherit_ngsign" model="ir.ui.view">
        <field name="name">account.invoice.tree.inherit.ngsign</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="payment_state" position="after">
                <field name="ngsign_status" optional="show" widget="badge"
                       decoration-success="ngsign_status == 'TTN Signed'"
                       decoration-info="ngsign_status == 'signed_ngsign'"
                       decoration-warning="ngsign_status == 'pending'"
                       decoration-danger="ngsign_status in ('error', 'TTN_REJECTED', 'CANCELLED')"/>
            </field>
        </field>
    </record>
    <record id="action_sign_ngsign_bulk" model="ir.actions.server">
        <field name="name">Sign with NGSign</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_sign_ngsign()
        </field>
    </record>

    <record id="action_generate_debug_json_bulk" model="ir.actions.server">
        <field name="name">Generate Debug JSON</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_generate_debug_json()
        </field>
    </record>
</odoo>
