<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_ngsign" model="ir.ui.view">
        <field name="name">res.partner.form.ngsign</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="NGSign" name="ngsign_configuration">
                    <group>
                        <field name="ngsign_notify_owner"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
