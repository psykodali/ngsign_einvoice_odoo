<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ngsign</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='invoicing_settings']" position="after">
                <h2>NGSign e-invoice</h2>
                <div class="row mt16 o_settings_container" id="ngsign_settings">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="ngsign_api_url"/>
                            <field name="ngsign_api_url"/>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="ngsign_login"/>
                            <field name="ngsign_login"/>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="ngsign_password"/>
                            <field name="ngsign_password" password="True"/>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="ngsign_passphrase"/>
                            <field name="ngsign_passphrase" password="True"/>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label for="ngsign_signer_email"/>
                            <field name="ngsign_signer_email"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
