<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.ngsign</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='general_settings']" position="inside">
                    <h2>NGSign e-invoice</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane">
                            </div>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">NGSign Configuration</span>
                                <div class="text-muted">
                                    Configure NGSign API for e-invoicing and SEAL signing
                                </div>
                                <div class="content-group mt16">
                                    <div class="row mt8">
                                        <label for="ngsign_api_einvoice_url" class="col-3 o_light_label"/>
                                        <field name="ngsign_api_einvoice_url" class="col-9"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="ngsign_bearer_token" class="col-3 o_light_label"/>
                                        <field name="ngsign_bearer_token" class="col-9"/>
                                    </div>
                                    
                                    <!-- Certificate Type Selection -->
                                    <div class="row mt16">
                                        <label for="ngsign_certificate_type" class="col-3 o_light_label" string="Certificate Type"/>
                                        <field name="ngsign_certificate_type" widget="radio" class="col-9"/>
                                    </div>
                                    
                                    <!-- SEAL-specific fields -->
                                    <div class="row mt8" invisible="ngsign_certificate_type != 'seal'">
                                        <label for="ngsign_passphrase" class="col-3 o_light_label"/>
                                        <field name="ngsign_passphrase" class="col-9" required="ngsign_certificate_type == 'seal'"/>
                                    </div>
                                    <div class="row mt8" invisible="ngsign_certificate_type != 'seal'">
                                        <label for="ngsign_use_v2_endpoint" class="col-3 o_light_label"/>
                                        <field name="ngsign_use_v2_endpoint" class="col-9"/>
                                    </div>
                                    
                                    <!-- DigiGO/SSCD-specific fields -->
                                    <div class="row mt8" invisible="ngsign_certificate_type == 'seal'">
                                        <label for="ngsign_pds_base_url" class="col-3 o_light_label"/>
                                        <field name="ngsign_pds_base_url" class="col-9"/>
                                    </div>
                                    
                                    <!-- Common fields -->
                                    <div class="row mt8">
                                        <label for="ngsign_signer_email" class="col-3 o_light_label"/>
                                        <field name="ngsign_signer_email" class="col-9"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="ngsign_notify_owner_default" class="col-3 o_light_label"/>
                                        <field name="ngsign_notify_owner_default" class="col-9"/>
                                    </div>
                                    
                                    <div class="row mt16" invisible="ngsign_certificate_type != 'seal'">
                                        <button name="action_open_ttn_layout_settings" string="BETA: Builtin (Seal V2) PDF generation Layout" type="object" class="oe_link" icon="fa-th-large"/>
                                    </div>
                                    <div class="row mt16" invisible="ngsign_certificate_type != 'seal'">
                                        <button name="action_open_template_settings" string="NGSIGN (Seal V1) PDF generation Layout" type="object" class="oe_link" icon="fa-arrow-right"/>
                                    </div>
                                    <div class="row mt16">
                                        <button name="action_open_developer_settings" string="Developer Options" type="object" class="oe_link" icon="fa-cogs"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
