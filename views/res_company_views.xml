<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_ngsign" model="ir.ui.view">
        <field name="name">res.company.form.inherit.ngsign</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="NGSign / TTN Layout">
                    <group>
                        <group string="QR Code Position (mm)">
                            <field name="ngsign_qr_position_x"/>
                            <field name="ngsign_qr_position_y"/>
                        </group>
                        <group string="Label Position (mm)">
                            <field name="ngsign_label_position_x"/>
                            <field name="ngsign_label_position_y"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
