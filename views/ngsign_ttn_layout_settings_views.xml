<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ngsign_ttn_layout_settings_form" model="ir.ui.view">
        <field name="name">ngsign.ttn.layout.settings.form</field>
        <field name="model">ngsign.ttn.layout.settings</field>
        <field name="arch" type="xml">
            <form string="TTN Layout Configuration">
                <group>
                    <group string="Preview">
                        <field name="preview_image" filename="preview_image_name" widget="binary" string="Upload Invoice Image (for preview)"/>
                        <field name="preview_image_name" invisible="1"/>
                        <field name="preview_html" nolabel="1" widget="html"/>
                    </group>
                </group>
                <group>
                    <!-- QR Code Settings -->
                    <div class="row mt16">
                        <div class="col-6">
                            <label for="ngsign_qr_position_x" class="o_form_label">QR X Position (mm)</label>
                            <field name="ngsign_qr_position_x"/>
                        </div>
                        <div class="col-6">
                            <label for="ngsign_qr_position_y" class="o_form_label">QR Y Position (mm)</label>
                            <field name="ngsign_qr_position_y"/>
                        </div>
                    </div>
                    <div class="row mt8">
                        <div class="col-6">
                            <label for="ngsign_qr_size" class="o_form_label">QR Size (mm)</label>
                            <field name="ngsign_qr_size"/>
                        </div>
                    </div>

                    <div class="o_horizontal_separator mt32">Reference Label Configuration</div>
                    <!-- Label Settings -->
                    <div class="row mt16">
                        <div class="col-6">
                            <label for="ngsign_label_position_x" class="o_form_label">Label X Position (mm)</label>
                            <field name="ngsign_label_position_x"/>
                        </div>
                        <div class="col-6">
                            <label for="ngsign_label_position_y" class="o_form_label">Label Y Position (mm)</label>
                            <field name="ngsign_label_position_y"/>
                        </div>
                    </div>
                    <div class="row mt8">
                        <div class="col-6">
                            <label for="ngsign_label_text" class="o_form_label">Optional Text Prefix</label>
                            <field name="ngsign_label_text" placeholder="e.g. TTN ID:"/>
                        </div>
                        <div class="col-6">
                            <label for="ngsign_label_width" class="o_form_label">Label Max Width (mm)</label>
                            <field name="ngsign_label_width"/>
                        </div>
                    </div>
                    <div class="row mt8">
                        <div class="col-6">
                            <label for="ngsign_label_font_size" class="o_form_label">Label Font Size (pt)</label>
                            <field name="ngsign_label_font_size"/>
                        </div>
                    </div>
                </group>
                <footer>
                    <button string="Save" type="object" name="action_save" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ngsign_ttn_layout_settings" model="ir.actions.act_window">
        <field name="name">TTN Layout Configuration</field>
        <field name="res_model">ngsign.ttn.layout.settings</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
