<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom paperformat with zero top margin for absolute QR positioning -->
    <record id="paperformat_a4_ngsign" model="report.paperformat">
        <field name="name">A4 - NGSign (No Top Margin)</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>
    
    <!-- Apply custom paperformat to invoice report -->
    <record id="account.account_invoices" model="ir.actions.report">
        <field name="paperformat_id" ref="paperformat_a4_ngsign"/>
    </record>
</odoo>
