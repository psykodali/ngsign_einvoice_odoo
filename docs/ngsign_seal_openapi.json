    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "schemas": {
            "Response_NGXMLInvoiceTransaction": {
                "type": "object",
                "properties": {
                    "object": {
                        "$ref": "#/components/schemas/NGXMLInvoiceTransaction"
                    },
                    "message": {
                        "type": "string"
                    },
                    "errorCode": {
                        "type": "integer"
                    }
                }
            },
            "NGXMLAdvancedInvoiceUpload": {
                "type": "object",
                "description": "Structure utilisée pour le téléchargement avancé de factures avec signataire et phrase de passe optionnelle pour le cachet.",
                "properties": {
                    "invoices": {
                        "type": "array",
                        "description": "Liste des factures à traiter.",
                        "items": {
                            "$ref": "#/components/schemas/NGXMLInvoiceUpload"
                        }
                    },
                    "signerEmail": {
                        "type": "string",
                        "description": "Email du signataire (doit faire partie de l'organisation)."
                    },
                    "passphrase": {
                        "type": "string",
                        "description": "Phrase de passe pour le cachet électronique (optionnel)."
                    },
                    "ccEmail": {
                        "type": "string",
                        "description": "Adresse email en copie (optionnel)."
                    }
                }
            },
            "Response_ByteArray": {
                "type": "object",
                "properties": {
                    "object": {
                        "type": "string",
                        "format": "byte"
                    },
                    "message": {
                        "type": "string"
                    },
                    "errorCode": {
                        "type": "integer"
                    }
                }
            },
            "Response_Void": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "errorCode": {
                        "type": "integer"
                    }
                }
            },
            "Response_NGXMLInvoice": {
                "type": "object",
                "properties": {
                    "object": {
                        "$ref": "#/components/schemas/NGXMLInvoice"
                    },
                    "message": {
                        "type": "string"
                    },
                    "errorCode": {
                        "type": "integer"
                    },
                    "ccEmail": {
                        "type": "string"
                    }
                }
            },
            "NGXMLCreationInvoiceUpload": {
                "type": "object",
                "description": "Structure pour la création d'un téléchargement de facture.",
                "properties": {
                    "invoices": {
                        "type": "array",
                        "description": "Liste des factures à télécharger.",
                        "items": {
                            "$ref": "#/components/schemas/NGXMLInvoiceUpload"
                        }
                    },
                    "signerEmail": {
                        "type": "string",
                        "description": "Email du signataire. Si null, le créateur est supposé être le signataire."
                    }
                }
            },
            "NGXMLInvoiceUpload": {
                "type": "object",
                "description": "Structure représentant une facture à télécharger.",
                "properties": {
                    "invoiceFileB64": {
                        "type": "string",
                        "description": "Contenu du fichier PDF encodé en Base64."
                    },
                    "configuration": {
                        "$ref": "#/components/schemas/InvoiceConfiguration"
                    },
                    "invoiceTIEF": {
                        "type": "string",
                        "description": "Contenu XML TEIF encodé en Base64."
                    },
                    "clientEmail": {
                        "type": "string",
                        "description": "Email du client."
                    },
                    "callbackUrl": {
                        "$ref": "#/components/schemas/NGCallbackUrl"
                    },
                    "invoiceNumber": {
                        "type": "string",
                        "description": "Numéro de facture."
                    }
                }
            },
            "NGXMLInvoiceTransaction": {
                "type": "object",
                "description": "Représente une transaction de facture XML contenant plusieurs factures.",
                "properties": {
                    "uuid": {
                        "type": "string",
                        "description": "Identifiant unique de la transaction."
                    },
                    "invoices": {
                        "type": "array",
                        "description": "Liste des factures dans la transaction.",
                        "items": {
                            "$ref": "#/components/schemas/NGXMLInvoice"
                        }
                    },
                    "creationDate": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Date de création."
                    },
                    "status": {
                        "type": "string",
                        "description": "Statut actuel de la transaction."
                    },
                    "digestAlgo": {
                        "type": "string",
                        "description": "Algorithme de digest utilisé."
                    },
                    "signingTime": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Heure de signature."
                    },
                    "creator": {
                        "$ref": "#/components/schemas/NGUser"
                    },
                    "user": {
                        "$ref": "#/components/schemas/NGUser"
                    },
                    "organization": {
                        "$ref": "#/components/schemas/NGLimitedOrganization"
                    },
                    "deleterId": {
                        "$ref": "#/components/schemas/NGUser"
                    },
                    "deleteDate": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Date de suppression."
                    },
                    "deleted": {
                        "type": "boolean",
                        "description": "Si la transaction est supprimée."
                    },
                    "locked": {
                        "type": "boolean",
                        "description": "Si la transaction est verrouillée."
                    },
                    "bySeal": {
                        "type": "boolean",
                        "description": "Signé par cachet électronique."
                    },
                    "bySealV2": {
                        "type": "boolean",
                        "description": "Signé par cachet V2 (sans PDF)."
                    },
                    "wsOnlyCreation": {
                        "type": "boolean",
                        "description": "Créé via Web Service uniquement."
                    }
                }
            },
            "NGXMLInvoice": {
                "type": "object",
                "description": "Représente une facture XML avec son statut et ses détails.",
                "properties": {
                    "status": {
                        "type": "string",
                        "description": "Statut de la facture."
                    },
                    "uuid": {
                        "type": "string",
                        "description": "Identifiant unique de la facture."
                    },
                    "clientEmail": {
                        "type": "string",
                        "description": "Email du client."
                    },
                    "ttnReference": {
                        "type": "string",
                        "description": "Référence générée par TTN."
                    },
                    "ttnErrorMessage": {
                        "type": "string",
                        "description": "Message d'erreur de TTN (si existant)."
                    },
                    "invoiceNumber": {
                        "type": "string",
                        "description": "Numéro de facture."
                    },
                    "invoiceDate": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Date de la facture."
                    },
                    "withPDF": {
                        "type": "boolean",
                        "description": "Si un PDF a été fourni."
                    },
                    "twoDocImage": {
                        "type": "string",
                        "format": "byte",
                        "description": "Image 2D-Doc (base64)."
                    },
                    "callbackUrl": {
                        "$ref": "#/components/schemas/NGCallbackUrl"
                    },
                    "fileSize": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Taille du fichier en octets."
                    }
                }
            },
            "InvoiceConfiguration": {
                "type": "object",
                "description": "Configuration pour le positionnement du QR et du libellé de la facture",
                "properties": {
                    "qrPositionX": {
                        "type": "integer"
                    },
                    "qrPositionY": {
                        "type": "integer"
                    },
                    "qrPositionP": {
                        "type": "integer"
                    },
                    "labelPositionX": {
                        "type": "integer"
                    },
                    "labelPositionY": {
                        "type": "integer"
                    },
                    "labelPositionP": {
                        "type": "integer"
                    },
                    "qrRatio": {
                        "type": "number",
                        "format": "float",
                        "default": 0.5
                    },
                    "textPositionX": {
                        "type": "integer"
                    },
                    "textPositionY": {
                        "type": "integer"
                    },
                    "textPage": {
                        "type": "integer"
                    },
                    "allPages": {
                        "type": "boolean",
                        "default": false
                    }
                }
            },
            "NGCallbackUrl": {
                "type": "object",
                "description": "Callback URL configuration",
                "properties": {
                    "successUrl": {
                        "type": "string"
                    },
                    "failureUrl": {
                        "type": "string"
                    }
                }
            },
            "NGUser": {
                "type": "object",
                "description": "User information",
                "properties": {
                    "email": {
                        "type": "string"
                    },
                    "firstName": {
                        "type": "string"
                    },
                    "lastName": {
                        "type": "string"
                    }
                },
                "additionalProperties": true
            },
            "NGLimitedOrganization": {
                "type": "object",
                "description": "Organization information",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "id": {
                        "type": "string"
                    }
                },
                "additionalProperties": true
            }
        }
    }
}