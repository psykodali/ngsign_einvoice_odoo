                    },
                    "ccEmail": {
                        "type": "string",
                        "description": "Copy email address (optional)."
                    }
                }
            },
            "Response_ByteArray": {
                "type": "object",
                "properties": {
                    "object": {
                        "type": "string",
                        "format": "byte"
                    },
                    "message": {
                        "type": "string"
                    },
                    "errorCode": {
                        "type": "integer"
                    }
                }
            },
            "Response_Void": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "errorCode": {
                        "type": "integer"
                    }
                }
            },
