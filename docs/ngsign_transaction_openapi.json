                        "description": "List of invoices to upload.",
                        "items": {
                            "$ref": "#/components/schemas/NGXMLInvoiceUpload"
                        }
                    },
                    "signerEmail": {
                        "type": "string",
                        "description": "Email of the signer. If null, the creator is assumed to be the signer."
                    }
                }
            },
            "NGXMLInvoiceUpload": {
                "type": "object",
                "description": "Structure representing an invoice to be uploaded.",
