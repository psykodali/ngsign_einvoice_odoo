                    "creationDate": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Date of creation."
                    },
                    "status": {
                        "type": "string",
                        "description": "Current status of the transaction."
                    },
                    "digestAlgo": {
                        "type": "string",
                        "description": "Digest algorithm used."
                    },
                    "signingTime": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Time of signing."
