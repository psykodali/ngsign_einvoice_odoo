                "type": "object",
                "properties": {
                    "object": {
                        "$ref": "#/components/schemas/NGXMLInvoice"
                    },
                    "message": {
                        "type": "string"
                    },
                    "errorCode": {
                        "type": "integer"
                    },
                    "ccEmail": {
                        "type": "string"
                    }
                }
            },
