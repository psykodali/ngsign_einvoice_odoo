                    "creator": {
                        "$ref": "#/components/schemas/NGUser"
                    },
                    "user": {
                        "$ref": "#/components/schemas/NGUser"
                    },
                    "organization": {
                        "$ref": "#/components/schemas/NGLimitedOrganization"
                    },
                    "deleterId": {
                        "$ref": "#/components/schemas/NGUser"
                    },
                    "deleteDate": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Date of deletion."
                    },
                    "deleted": {
                        "type": "boolean",
                        "description": "Whether the transaction is deleted."
                    },
                    "locked": {
                        "type": "boolean",
                        "description": "Whether the transaction is locked."
                    },
                    "bySeal": {
                        "type": "boolean",
                        "description": "Signed by electronic seal."
                    },
                    "bySealV2": {
                        "type": "boolean",
                        "description": "Signed by seal V2 (no PDF)."
                    },
                    "wsOnlyCreation": {
                        "type": "boolean",
                        "description": "Created via Web Service only."
                    }
                }
            },
            "NGXMLInvoice": {
                "type": "object",
                "description": "Represents an XML invoice with its status and details.",
                "properties": {
                    "status": {
                        "type": "string",
                        "description": "Status of the invoice."
                    },
                    "uuid": {
                        "type": "string",
                        "description": "Unique invoice identifier."
                    },
                    "clientEmail": {
                        "type": "string",
                        "description": "Client email."
                    },
                    "ttnReference": {
                        "type": "string",
                        "description": "Reference generated by TTN."
                    },
                    "ttnErrorMessage": {
                        "type": "string",
                        "description": "Error message from TTN (if any)."
                    },
                    "invoiceNumber": {
                        "type": "string",
                        "description": "Invoice number."
                    },
                    "invoiceDate": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Date of the invoice."
                    },
                    "withPDF": {
                        "type": "boolean",
                        "description": "Whether a PDF was provided."
                    },
                    "twoDocImage": {
                        "type": "string",
                        "format": "byte",
                        "description": "2D-Doc image (base64)."
                    },
                    "callbackUrl": {
                        "$ref": "#/components/schemas/NGCallbackUrl"
                    },
                    "fileSize": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Size of the file in bytes."
                    }
                }
            },
            "InvoiceConfiguration": {
                "type": "object",
                "description": "Configuration for the invoice QR and Label positioning",
                "properties": {
                    "qrPositionX": {
                        "type": "integer"
                    },
                    "qrPositionY": {
                        "type": "integer"
                    },
                    "qrPositionP": {
                        "type": "integer"
                    },
                    "labelPositionX": {
                        "type": "integer"
                    },
                    "labelPositionY": {
                        "type": "integer"
                    },
                    "labelPositionP": {
                        "type": "integer"
                    },
                    "qrRatio": {
                        "type": "number",
                        "format": "float",
                        "default": 0.5
                    },
                    "textPositionX": {
                        "type": "integer"
                    },
                    "textPositionY": {
                        "type": "integer"
                    },
                    "textPage": {
                        "type": "integer"
                    },
                    "allPages": {
                        "type": "boolean",
                        "default": false
                    }
                }
            },
            "NGCallbackUrl": {
                "type": "object",
                "description": "Callback URL configuration",
                "properties": {
                    "successUrl": {
                        "type": "string"
                    },
                    "failureUrl": {
                        "type": "string"
                    }
                }
            },
            "NGUser": {
                "type": "object",
